# CloudPanel environment example
NODE_ENV=development

# Public URLs and ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# PostgreSQL container credentials
POSTGRES_USER=cloudpanel
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=cloudpanel
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cloudpanel:change-me-db-password@postgres:5432/cloudpanel?schema=public

# Redis and MinIO
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend secrets
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
API_KEY_PEPPER=change-me-api-key-pepper

# OAuth / SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CloudPanel <noreply@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Storage / integrations
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cloudpanel-backups
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
PTERODACTYL_URL=
PTERODACTYL_API_KEY=
WHMCS_API_KEY=change-me-whmcs-key
PAYMENTER_API_KEY=change-me-paymenter-key
